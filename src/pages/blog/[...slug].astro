---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const entry = await getEntry('blog', slug);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await entry.render();

const dateFormatted = entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${entry.data.title} | ProxLock Blog`} description={entry.data.description}>
    <div class="landing-page">
        <Navigation isScrolled={true} showWaitlist={true} />

        <!-- Header exactly matches Pricing layout pattern -->
        <header class="pricing-page" style="min-height: auto; padding-top: 120px; padding-bottom: 0;">
            <div class="container pricing-container blog-post-outer" style="padding-top: 0; padding-bottom: 1.5rem;">
                <div class="blog-meta" style="justify-content: flex-start; margin-bottom: 1.5rem;">
                    <time datetime={entry.data.pubDate.toISOString()} class="blog-date">{dateFormatted}</time>
                    {entry.data.category && (
                        <span class="blog-category">{entry.data.category}</span>
                    )}
                </div>

                <h1 class="section-title pricing-title" style="margin-bottom: 1rem;">{entry.data.title}</h1>
                <p class="pricing-subtitle" style="margin-bottom: 2rem;">by ProxLock Team</p>
            </div>
        </header>

        <!-- Blog content separated into its own home-page style section -->
        <section class="blog-section" style="padding: 2rem 0 6rem; background: var(--bg-section); border-top: 1px solid var(--border-primary);">
            <div class="container blog-post-outer" style="margin: 0 auto;">
                {entry.data.image && (
                    <div class="blog-post-featured-image" style="margin-top: 0; margin-bottom: 3rem;">
                        <img src={entry.data.image} alt={`Illustration for ${entry.data.title}`} />
                    </div>
                )}

                <!-- Post Body -->
                <div class="blog-post-body" id="markdown-content">
                    <Content />
                </div>

                <!-- Navigation -->
                <div class="blog-post-navigation">
                    <a href="/blog" class="btn btn-secondary back-to-blog">← Back to Blog</a>
                </div>
            </div>
        </section>

        <Footer />
    </div>
</Layout>
